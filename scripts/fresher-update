#!/usr/bin/env bash
# fresher-update — Download and install the latest fresh binary
# Repository: https://github.com/nicolaslima/fresher
#
# Detects your platform and downloads the correct artifact from the
# latest CI run (or release). Installs to ~/.local/bin/fresh.
# Also creates a 'fresher' symlink alias for convenience.

set -euo pipefail

REPO="nicolaslima/fresher"
INSTALL_DIR="${HOME}/.local/bin"
BIN_NAME="fresh"

# ── Platform detection ──────────────────────────────────────────────
OS="$(uname -s)"
ARCH="$(uname -m)"

case "${OS}" in
  Darwin)
    case "${ARCH}" in
      x86_64)  TARGET="x86_64-apple-darwin"     ;;
      arm64)   TARGET="aarch64-apple-darwin"     ;;
      *)       echo "❌ Unsupported arch: ${ARCH} on macOS"; exit 1 ;;
    esac
    ;;
  Linux)
    case "${ARCH}" in
      x86_64)  TARGET="x86_64-unknown-linux-gnu"  ;;
      aarch64) TARGET="aarch64-unknown-linux-gnu"  ;;
      *)       echo "❌ Unsupported arch: ${ARCH} on Linux"; exit 1 ;;
    esac
    ;;
  MINGW*|MSYS*|CYGWIN*)
    case "${ARCH}" in
      x86_64)  TARGET="x86_64-pc-windows-msvc"   ;;
      arm64)   TARGET="aarch64-pc-windows-msvc"   ;;
      *)       echo "❌ Unsupported arch: ${ARCH} on Windows"; exit 1 ;;
    esac
    ;;
  *)
    echo "❌ Unsupported OS: ${OS}"
    exit 1
    ;;
esac

echo "🔍 Platform: ${OS} / ${ARCH} → ${TARGET}"

# ── Determine archive extension ────────────────────────────────────
case "${TARGET}" in
  *-windows-*) EXT="zip"   ;;
  *)           EXT="tar.xz" ;;
esac

ARTIFACT_NAME="fresh-${TARGET}"
ARCHIVE_NAME="fresh-${TARGET}.${EXT}"

# ── Try release first, fall back to CI artifact ─────────────────────
DOWNLOAD_DIR="/tmp/fresher-update-$$"
mkdir -p "${DOWNLOAD_DIR}"
trap 'rm -rf "${DOWNLOAD_DIR}"' EXIT

LATEST_TAG=$(gh release view --repo "${REPO}" --json tagName --jq '.tagName' 2>/dev/null || true)

if [ -n "${LATEST_TAG}" ]; then
  echo "📥 Downloading ${LATEST_TAG} for ${TARGET}..."
  gh release download "${LATEST_TAG}" \
    --repo "${REPO}" \
    --pattern "${ARCHIVE_NAME}" \
    --pattern "${ARCHIVE_NAME}.sha256" \
    --dir "${DOWNLOAD_DIR}" 2>/dev/null || true
fi

# If release download didn't produce the file, try CI artifact
if [ ! -f "${DOWNLOAD_DIR}/${ARCHIVE_NAME}" ]; then
  echo "⚠️  No matching release asset found. Trying latest CI artifact..."
  RUN_ID=$(gh run list --repo "${REPO}" --branch master --workflow "Build Fresh" --limit 1 \
    --json databaseId --jq '.[0].databaseId' 2>/dev/null || true)

  if [ -z "${RUN_ID}" ]; then
    echo "❌ No CI run found. Run 'gh workflow run \"Build Fresh\" --repo ${REPO}' first."
    exit 1
  fi

  echo "📥 Downloading CI artifact from run ${RUN_ID}..."
  gh run download "${RUN_ID}" \
    --repo "${REPO}" \
    --name "${ARTIFACT_NAME}" \
    --dir "${DOWNLOAD_DIR}" 2>/dev/null || true
fi

# ── Verify download ─────────────────────────────────────────────────
ARCHIVE_PATH="${DOWNLOAD_DIR}/${ARCHIVE_NAME}"
if [ ! -f "${ARCHIVE_PATH}" ]; then
  echo "❌ Failed to download ${ARCHIVE_NAME}"
  exit 1
fi

# ── Extract and install ─────────────────────────────────────────────
echo "📦 Extracting ${ARCHIVE_NAME}..."
cd "${DOWNLOAD_DIR}"

case "${EXT}" in
  tar.xz) tar -xf "${ARCHIVE_NAME}" ;;
  zip)    unzip -qo "${ARCHIVE_NAME}" ;;
esac

# Find the binary (might be in a subdirectory)
BINARY_PATH=$(find "${DOWNLOAD_DIR}" -name "${BIN_NAME}" -type f ! -path "*/${ARCHIVE_NAME}/*" | head -1)
if [ -z "${BINARY_PATH}" ]; then
  # Try inside the archive directory
  BINARY_PATH=$(find "${DOWNLOAD_DIR}/${ARTIFACT_NAME}" -name "${BIN_NAME}" -type f 2>/dev/null | head -1)
fi

if [ -z "${BINARY_PATH}" ]; then
  echo "❌ Binary '${BIN_NAME}' not found in archive"
  exit 1
fi

mkdir -p "${INSTALL_DIR}"

# Backup existing binary
if [ -f "${INSTALL_DIR}/${BIN_NAME}" ]; then
  cp "${INSTALL_DIR}/${BIN_NAME}" "${INSTALL_DIR}/${BIN_NAME}.bak"
  echo "💾 Backed up existing binary to ${BIN_NAME}.bak"
fi

cp "${BINARY_PATH}" "${INSTALL_DIR}/${BIN_NAME}"
chmod +x "${INSTALL_DIR}/${BIN_NAME}"

# Create 'fresher' alias (symlink)
ln -sf "${INSTALL_DIR}/${BIN_NAME}" "${INSTALL_DIR}/fresher"

echo ""
echo "✅ Installed ${BIN_NAME} to ${INSTALL_DIR}/${BIN_NAME}"
echo "✅ Alias 'fresher' → '${BIN_NAME}' created"
echo ""
echo "   Run '${BIN_NAME} --version' or 'fresher --version' to verify"
